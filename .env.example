# ===========================================================================
# Variables de entorno del backend InostraTech (EJEMPLO)
# ---------------------------------------------------------------------------
# Copia este archivo, NO subas el real. En Render se definen en el panel
# (Environment). En local puedes exportarlas en tu terminal antes de arrancar.
# Ningun valor real (claves, App Password, secretos) debe quedar en el repo.
# ===========================================================================

# --- Base de datos ---
# En desarrollo, si no defines nada, se usa H2 en memoria.
# Para PostgreSQL (Neon), usa formato JDBC y separa usuario/clave:
#   Neon te da: postgresql://USUARIO:CLAVE@HOST/BASE?sslmode=require
#   Conviertelo a:
DATABASE_URL=jdbc:postgresql://TU-HOST.neon.tech/TU-BASE?sslmode=require
DB_USERNAME=tu_usuario_neon
DB_PASSWORD=tu_password_neon

# --- Seguridad JWT ---
# Cadena larga y aleatoria (>= 32 caracteres). NO reutilices el valor de ejemplo.
JWT_SECRET=pon-aqui-una-clave-larga-y-aleatoria-de-al-menos-32-caracteres

# --- CORS: dominio del frontend (Vercel) ---
CORS_ALLOWED_ORIGIN=https://tu-frontend.vercel.app

# --- Correo (Gmail con App Password) ---
MAIL_USERNAME=tucorreo@gmail.com
MAIL_PASSWORD=tu_app_password_de_16_caracteres_sin_espacios
VENDEDOR_EMAIL=tucorreo@gmail.com

# --- WhatsApp del vendedor (codigo pais, sin "+") ---
VENDEDOR_WHATSAPP=569XXXXXXXX

# --- Cloudinary (opcional: si no se define, las imagenes se guardan locales) ---
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# --- Usuario admin semilla (cambia la clave en produccion) ---
ADMIN_EMAIL=admin@inostratech.cl
ADMIN_PASSWORD=cambia-esta-clave
ADMIN_NOMBRE=Administrador
